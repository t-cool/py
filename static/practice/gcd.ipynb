      "source": [
        "def gcd(a, b):\n",
        "    if a < b:\n",
        "        a, b = b, a\n",
        "    while b != 0:\n",
        "        a, b = b, a % b\n",
        "    return a\n",
        "\n",
        "print(gcd(12, 16))"
      ],
