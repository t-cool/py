      "source": [
        "def is_prime_number(n):\n",
        "    if n < 2:\n",
        "        return False\n",
        "    for i in range(2, n):\n",
        "        if n % i == 0:\n",
        "            return False\n",
        "    return True\n",
        "\n",
        "def print_prime_number(n):\n",
        "    for i in range(1, n + 1):\n",
        "        if is_prime_number(i):\n",
        "            print(i)\n",
        "\n",
        "print_prime_number(100)"
      ],
      "cell_type": "code",
